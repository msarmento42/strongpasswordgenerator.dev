{
  "allowed_paths": [
    "src/**",
    "public/**",
    "package.json",
    "next.config.ts",
    "postcss.config.mjs",
    "tsconfig.json",
    "eslint.config.mjs",
    "README.md"
  ],
  "blocked_paths": [
    ".github/**",
    ".agios/**",
    "*.env*",
    "vercel.json",
    "package-lock.json"
  ],
  "max_files_changed": 20,
  "note": "Codex must not touch CI config, AGIOS config, env files, or vercel.json."
}
